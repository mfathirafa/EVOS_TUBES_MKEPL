{
  "name": "task-manager-api",
  "version": "1.0.0",
  "description": "Simple Task Manager REST API — CI/CD Demo Project (MKPL)",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --coverage",
    "lint": "node --check src/app.js && node --check src/routes/tasks.js && echo 'Syntax check passed'"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 60,
        "statements": 70
      }
    }
  }
}
